{
  "$schema": "openclaw-config",
  "_comment": "Frozen benchmark config — identical for all memory system runs",
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": ["http://localhost:18789", "http://127.0.0.1:18789"]
    }
  },
  "agents": {
    "defaults": {
      "model": "anthropic/claude-sonnet-4-6",
      "maxTokens": 4096,
      "sandbox": {
        "mode": "off"
      }
    },
    "list": [
      {
        "id": "bench-agent",
        "name": "Benchmark Agent",
        "workspace": "/home/node/.openclaw/workspace/bench-agent",
        "model": "anthropic/claude-sonnet-4-6",
        "maxTokens": 4096
      }
    ]
  },
  "hooks": {
    "dir": "/home/node/.openclaw/hooks"
  }
}
