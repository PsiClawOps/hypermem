{
  "name": "@psiclawops/hypercompositor",
  "version": "0.5.4",
  "description": "HyperCompositor — context engine plugin for OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "license": "Apache-2.0",
  "author": "PsiClawOps",
  "repository": {
    "type": "git",
    "url": "https://github.com/PsiClawOps/hypermem-internal.git",
    "directory": "plugin"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "openclaw": {
    "plugin": {
      "id": "hypercompositor",
      "name": "HyperCompositor — Context Engine",
      "kind": "context-engine"
    },
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@psiclawops/hypermem": "^0.5.2"
  },
  "devDependencies": {
    "openclaw": "*",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "context-engine",
    "hypermem"
  ],
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ]
}
